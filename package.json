{
  "name": "xiaoke-desktop-pet",
  "version": "6.2.0",
  "description": "小柯桌面萌宠 v6.2 - 透明无背景的柯南Q版陪伴萌宠：保留全部玩法(摸摸/喂食/打工/商店/装扮/任务/案件/分享/设置/等级金币)，瞳孔直接绘入人物图跟随鼠标，新增屏幕溜达散步与更丰富的时段/待机情感碎碎念",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "electron-builder --publish=always"
  },
  "author": "XiaoKe",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.xiaoke.desktoppet",
    "productName": "小柯桌面萌宠",
    "copyright": "Copyright (c) 2026",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "images.js",
      "package.json"
    ],
    "extraResources": [
      "tray-icon.png",
      "app-update.yml"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "小柯桌面萌宠-便携版-${version}.${ext}",
      "requestExecutionLevel": "user"
    },
    "publish": {
      "provider": "github",
      "owner": "liangbai666",
      "repo": "xiaoke-desktop-pet"
    }
  }
}
